  28   1        P4M1 &= ~0x80;  P4M0 |=  0x80;   // P4.7: Push-Pull
  29   1        P4M1 |=  0x40;  P4M0 &= ~0x40;   // P4.6: High-Z Input
  30   1      
  31   1        // 配置 Timer2 为 1T 模式，作为 UART2 波特率发生器
  32   1        reload = 65536 - (11059200 / baudrate);
  33   1        AUXR &= ~0x18;          // 清除 T2R (bit4) 和 T2_CT (bit3)
  34   1        AUXR |=  0x04;          // 设置 T2x12=1 (1T mode)
  35   1        if(baudrate == 1200){
