 523   1          WriteRawRC(reg,tmp | mask);  // set bit mask
 524   1      }
 525          
 526          /////////////////////////////////////////////////////////////////////
 527          //功    能：清RC522寄存器位
 528          //参数说明：reg[IN]:寄存器地址
 529          //          mask[IN]:清位值
 530          /////////////////////////////////////////////////////////////////////
 531          void ClearBitMask(unsigned char reg,unsigned char mask)  
 532          {
 533   1          xdata char tmp = 0x0;
 534   1          tmp = ReadRawRC(reg);
 535   1          WriteRawRC(reg, tmp & ~mask);  // clear bit mask
 536   1      } 
