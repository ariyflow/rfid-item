  55          // 发送一个字节，返回 ACK (0=ACK, 1=NACK)
  56          bit I2C_WriteByte(unsigned char dat){
  57   1          xdata unsigned char i;
  58   1          bit ack;
  59   1          for(i = 0; i < 8; i++){
  60   2              if (dat & 0x80) SDA = 1; else SDA = 0;
  61   2              dat <<= 1;
  62   2              delay_us(5);
  63   2              SCL = 1;
  64   2              delay_us(5);
  65   2              SCL = 0;
  66   2          }
  67   1          SDA = 1;  // 释放 SDA
  68   1          delay_us(5);
  69   1          SCL = 1;
  70   1          delay_us(5);
  71   1          ack = SDA;  // 读 ACK
  72   1          SCL = 0;
  73   1          return ack;
  74   1      }
