 373          /////////////////////////////////////////////////////////////////////
 374          //用MF522计算CRC16函数
 375          /////////////////////////////////////////////////////////////////////
 376          void CalulateCRC(unsigned char *pIndata,unsigned char len,unsigned char *pOutData)
 377          {
 378   1          xdata unsigned char i,n;
 379   1          ClearBitMask(DivIrqReg,0x04);
 380   1          WriteRawRC(CommandReg,PCD_IDLE);
 381   1          SetBitMask(FIFOLevelReg,0x80);
 382   1          for (i=0; i<len; i++)
 383   1          {   WriteRawRC(FIFODataReg, *(pIndata+i));   }
 384   1          WriteRawRC(CommandReg, PCD_CALCCRC);
 385   1          i = 0xFF;
 386   1          do 
 387   1          {
 388   2              n = ReadRawRC(DivIrqReg);
 389   2              i--;
 390   2          }
 391   1          while ((i!=0) && !(n&0x04));
 392   1          pOutData[0] = ReadRawRC(CRCResultRegL);
 393   1          pOutData[1] = ReadRawRC(CRCResultRegM);
 394   1      }
