 633          /////////////////////////////////////////////////////////////////////
 634          //开启天线  
 635          //每次启动或关闭天险发射之间应至少有1ms的间隔
 636          /////////////////////////////////////////////////////////////////////
 637          void PcdAntennaOn()
 638          {
 639   1          xdata unsigned char i;
 640   1          i = ReadRawRC(TxControlReg);
 641   1          if (!(i & 0x03))
 642   1          {
 643   2              SetBitMask(TxControlReg, 0x03);
 644   2          }
 645   1      }
 646          
 647          
 648          /////////////////////////////////////////////////////////////////////
 649          //关闭天线
 650          /////////////////////////////////////////////////////////////////////
 651          void PcdAntennaOff()
 652          {
 653   1          ClearBitMask(TxControlReg, 0x03);
 654   1      }


