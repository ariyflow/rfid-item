 427          unsigned char ReadRawRC(unsigned char Address)
 428          {
 429   1          xdata unsigned char i, ucAddr;
 430   1          xdata unsigned char ucResult = 0;
 431   1        
 432   1          EA = 0; // 关闭中断
 433   1          
 434   1          MF522_SCK = 1;        // 空闲状态
 435   1          MF522_NSS = 0;        // 片选有效
 436   1          
 437   1          // 地址格式：[6 位地址][1 位 1(读)][1 位 0]
 438   1          ucAddr = ((Address << 1) & 0x7E) | 0x80;
 439   1          
 440   1          // 发送地址
 441   1          for(i = 8; i > 0; i--) {
 442   2              MF522_SI = !((ucAddr & 0x80) == 0x80); // 取反
 443   2              MF522_SCK = 0;
 444   2              ucAddr <<= 1;
 445   2              MF522_SCK = 1;
 446   2          }
 447   1          
 448   1          // 接收数据
 449   1          for(i = 8; i > 0; i--) {
 450   2              MF522_SCK = 0;    // 产生时钟
 451   2              ucResult <<= 1;
 452   2              
 453   2              // 【关键】MISO 直连，直接读取，不用取反
 454   2              if(MF522_SO) {
 455   3                  ucResult |= 0x01;
 456   3              }
 457   2              
 458   2              MF522_SCK = 1;    // 恢复空闲
 459   2          }
 460   1          
 461   1          MF522_NSS = 1;
 462   1          MF522_SCK = 1;
 463   1          
 464   1          EA = 1; // 恢复中断
 465   1          
 466   1          return ucResult;
 467   1           
 468   1      }
