  11          // p4.1-p4.4需要取反, P1.0-p1.1不需要取反
  12          void rc522Init(){
  13   1          EA = 0;
  14   1          // 1. 配置 P4 口为推挽输出 (驱动反向器)
  15   1          P4M1 &= 0xE1;   // 1110 0001
  16   1          P4M0 |= 0x1E;   // 0001 1110 (P4.1-P4.4 推挽)
  17   1          
  18   1          // 2. 配置 P1.0 为高阻输入 (MISO)
  19   1          P1M1 |= 0x01;
  20   1          P1M0 &= 0xFE;
  21   1          
  22   1          // 3. 配置 P1.1 为推挽输出 (NSS)
  23   1          P1M1 &= 0xFD;
  24   1          P1M0 |= 0x02;
  25   1          
  26   1          // 4. 初始电平状态
  27   1          MF522_NSS = 1;      // 未选中
  28   1          MF522_SCK = 1;      // 空闲 (物理低)
  29   1          MF522_SI  = 1;      // 空闲 (物理低)
  30   1          MF522_SO  = 0;      // 输入无关
  31   1          
  32   1          // 5. 设置 RC522 通信模式 (SPI)
  33   1          // 指导书：EA=1, IIC=0 表示 SPI (因有反向器，MCU 输出相反)
  34   1          MF522_EA  = 0;      // 物理 1
  35   1          MF522_IIC = 1;      // 物理 0 (SPI 模式)
  36   1          
  37   1          // 6. 软复位
  38   1          // WriteRawRC(CommandReg, 0x0F); // SoftReset
  39   1      
  40   1        PcdReset();
  41   1        PcdAntennaOff();
  42   1        PcdAntennaOn();
  43   1        EA = 1;
  44   1      }
