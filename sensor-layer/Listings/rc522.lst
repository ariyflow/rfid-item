 513          /////////////////////////////////////////////////////////////////////
 514          //功    能：置RC522寄存器位
 515          //参数说明：reg[IN]:寄存器地址
 516          //          mask[IN]:置位值
 517          /////////////////////////////////////////////////////////////////////
 518          void SetBitMask(unsigned char reg,unsigned char mask)  
 519          {
 520   1          xdata char tmp = 0x0;
 521   1          tmp = ReadRawRC(reg);
 522   1          WriteRawRC(reg,tmp | mask);  // set bit mask
 523   1      }
 524          
 525          /////////////////////////////////////////////////////////////////////
 526          //功    能：清RC522寄存器位
 527          //参数说明：reg[IN]:寄存器地址
 528          //          mask[IN]:清位值
 529          /////////////////////////////////////////////////////////////////////
 530          void ClearBitMask(unsigned char reg,unsigned char mask)  
 531          {
 532   1          xdata char tmp = 0x0;
 533   1          tmp = ReadRawRC(reg);
 534   1          WriteRawRC(reg, tmp & ~mask);  // clear bit mask
 535   1      } 
 536          
 537          /////////////////////////////////////////////////////////////////////
 538          //功    能：通过RC522和ISO14443卡通讯
 539          //参数说明：Command[IN]:RC522命令字
 540          //          pInData[IN]:通过RC522发送到卡片的数据
 541          //          InLenByte[IN]:发送数据的字节长度
 542          //          pOutData[OUT]:接收到的卡片返回数据
 543          //          *pOutLenBit[OUT]:返回数据的位长度
 544          /////////////////////////////////////////////////////////////////////
 545          char PcdComMF522(unsigned char Command, 
 546                           unsigned char *pInData, 
 547                           unsigned char InLenByte,
 548                           unsigned char *pOutData, 
 549                           unsigned int  *pOutLenBit)
 550          {
C51 COMPILER V9.54   RC522                                                                 05/10/2026 11:00:13 PAGE 10  

 551   1          xdata char status = MI_ERR;
 552   1          //char status = 0;
 553   1          xdata unsigned char irqEn   = 0x00;
 554   1          xdata unsigned char waitFor = 0x00;
 555   1          xdata unsigned char lastBits;
 556   1          xdata unsigned char n;
 557   1          xdata unsigned int i;
 558   1          switch (Command)
 559   1          {
 560   2             case PCD_AUTHENT:
 561   2                irqEn   = 0x12;
 562   2                waitFor = 0x10;
 563   2                break;
 564   2             case PCD_TRANSCEIVE:
 565   2                irqEn   = 0x77;
 566   2                waitFor = 0x30;
 567   2                break;
 568   2             default:
 569   2               break;
 570   2          }
 571   1         
 572   1          WriteRawRC(ComIEnReg,irqEn|0x80);
 573   1          ClearBitMask(ComIrqReg,0x80);
 574   1          WriteRawRC(CommandReg,PCD_IDLE);
 575   1          SetBitMask(FIFOLevelReg,0x80);
 576   1          
 577   1          for (i=0; i<InLenByte; i++)
 578   1          {   WriteRawRC(FIFODataReg, pInData[i]);    }
 579   1          WriteRawRC(CommandReg, Command);
 580   1         
 581   1          
 582   1          if (Command == PCD_TRANSCEIVE)
 583   1          {    SetBitMask(BitFramingReg,0x80);  }
 584   1          
 585   1          i = 600;//根据时钟频率调整，操作M1卡最大等待时间25ms
 586   1          do 
 587   1          {
 588   2               n = ReadRawRC(ComIrqReg);
 589   2               i--;
 590   2          }
 591   1          while ((i!=0) && !(n&0x01) && !(n&waitFor));
 592   1          ClearBitMask(BitFramingReg,0x80);
 593   1          //status = 1;   
 594   1          if (i!=0)
 595   1          {    
 596   2               if(!(ReadRawRC(ErrorReg)&0x1B))
 597   2               {
 598   3                   status = MI_OK;
 599   3                   if (n & irqEn & 0x01)
 600   3                   {   status = MI_NOTAGERR;   }
 601   3                   if (Command == PCD_TRANSCEIVE)
 602   3                   {
 603   4                      n = ReadRawRC(FIFOLevelReg);
 604   4                      lastBits = ReadRawRC(ControlReg) & 0x07;
 605   4      
 606   4            
 607   4                      if (lastBits)
 608   4                      {   *pOutLenBit = (n-1)*8 + lastBits;   }
 609   4                      else
 610   4                      {   *pOutLenBit = n*8;   }
 611   4                      if (n == 0)
 612   4                      {   n = 1;    }
C51 COMPILER V9.54   RC522                                                                 05/10/2026 11:00:13 PAGE 11  

 613   4                      if (n > MAXRLEN)
 614   4                      {   n = MAXRLEN;   }
 615   4                      for (i=0; i<n; i++)
 616   4                      {   pOutData[i] = ReadRawRC(FIFODataReg);    }      
 617   4                  }
 618   3               }
 619   2               else
 620   2               {   status = MI_ERR; 
 621   3                 //  status = 1;
 622   3               }
 623   2              
 624   2         }
 625   1         
 626   1      
 627   1         SetBitMask(ControlReg,0x80);           // stop timer now
 628   1         WriteRawRC(CommandReg,PCD_IDLE); 
 629   1         return status;
 630   1      }
