 374          /////////////////////////////////////////////////////////////////////
 375          //用MF522计算CRC16函数
 376          /////////////////////////////////////////////////////////////////////
 377          void CalulateCRC(unsigned char *pIndata,unsigned char len,unsigned char *pOutData)
 378          {
 379   1          xdata unsigned char i,n;
 380   1          ClearBitMask(DivIrqReg,0x04);
 381   1          WriteRawRC(CommandReg,PCD_IDLE);
 382   1          SetBitMask(FIFOLevelReg,0x80);
 383   1          for (i=0; i<len; i++)
 384   1          {   WriteRawRC(FIFODataReg, *(pIndata+i));   }
 385   1          WriteRawRC(CommandReg, PCD_CALCCRC);
 386   1          i = 0xFF;
 387   1          do 
 388   1          {
 389   2              n = ReadRawRC(DivIrqReg);
 390   2              i--;
 391   2          }
 392   1          while ((i!=0) && !(n&0x04));
 393   1          pOutData[0] = ReadRawRC(CRCResultRegL);
 394   1          pOutData[1] = ReadRawRC(CRCResultRegM);
 395   1      }
