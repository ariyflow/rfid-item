 538          /////////////////////////////////////////////////////////////////////
 539          //功    能：通过RC522和ISO14443卡通讯
 540          //参数说明：Command[IN]:RC522命令字
 541          //          pInData[IN]:通过RC522发送到卡片的数据
 542          //          InLenByte[IN]:发送数据的字节长度
 543          //          pOutData[OUT]:接收到的卡片返回数据
 544          //          *pOutLenBit[OUT]:返回数据的位长度
 545          /////////////////////////////////////////////////////////////////////
 546          char PcdComMF522(unsigned char Command, 
 547                           unsigned char *pInData, 
 548                           unsigned char InLenByte,
 549                           unsigned char *pOutData, 
 550                           unsigned int  *pOutLenBit)
C51 COMPILER V9.54   RC522                                                                 03/23/2026 23:17:59 PAGE 10  

 551          {
 552   1          xdata char status = MI_ERR;
 553   1          //char status = 0;
 554   1          xdata unsigned char irqEn   = 0x00;
 555   1          xdata unsigned char waitFor = 0x00;
 556   1          xdata unsigned char lastBits;
 557   1          xdata unsigned char n;
 558   1          xdata unsigned int i;
 559   1          switch (Command)
 560   1          {
 561   2             case PCD_AUTHENT:
 562   2                irqEn   = 0x12;
 563   2                waitFor = 0x10;
 564   2                break;
 565   2             case PCD_TRANSCEIVE:
 566   2                irqEn   = 0x77;
 567   2                waitFor = 0x30;
 568   2                break;
 569   2             default:
 570   2               break;
 571   2          }
 572   1         
 573   1          WriteRawRC(ComIEnReg,irqEn|0x80);
 574   1          ClearBitMask(ComIrqReg,0x80);
 575   1          WriteRawRC(CommandReg,PCD_IDLE);
 576   1          SetBitMask(FIFOLevelReg,0x80);
 577   1          
 578   1          for (i=0; i<InLenByte; i++)
 579   1          {   WriteRawRC(FIFODataReg, pInData[i]);    }
 580   1          WriteRawRC(CommandReg, Command);
 581   1         
 582   1          
 583   1          if (Command == PCD_TRANSCEIVE)
 584   1          {    SetBitMask(BitFramingReg,0x80);  }
 585   1          
 586   1          i = 600;//根据时钟频率调整，操作M1卡最大等待时间25ms
 587   1          do 
 588   1          {
 589   2               n = ReadRawRC(ComIrqReg);
 590   2               i--;
 591   2          }
 592   1          while ((i!=0) && !(n&0x01) && !(n&waitFor));
 593   1          ClearBitMask(BitFramingReg,0x80);
 594   1          //status = 1;   
 595   1          if (i!=0)
 596   1          {    
 597   2               if(!(ReadRawRC(ErrorReg)&0x1B))
 598   2               {
 599   3                   status = MI_OK;
 600   3                   if (n & irqEn & 0x01)
 601   3                   {   status = MI_NOTAGERR;   }
 602   3                   if (Command == PCD_TRANSCEIVE)
 603   3                   {
 604   4                      n = ReadRawRC(FIFOLevelReg);
 605   4                      lastBits = ReadRawRC(ControlReg) & 0x07;
 606   4      
 607   4            
 608   4                      if (lastBits)
 609   4                      {   *pOutLenBit = (n-1)*8 + lastBits;   }
 610   4                      else
 611   4                      {   *pOutLenBit = n*8;   }
 612   4                      if (n == 0)
C51 COMPILER V9.54   RC522                                                                 03/23/2026 23:17:59 PAGE 11  

 613   4                      {   n = 1;    }
 614   4                      if (n > MAXRLEN)
 615   4                      {   n = MAXRLEN;   }
 616   4                      for (i=0; i<n; i++)
 617   4                      {   pOutData[i] = ReadRawRC(FIFODataReg);    }      
 618   4                  }
 619   3               }
 620   2               else
 621   2               {   status = MI_ERR; 
 622   3                 //  status = 1;
 623   3               }
 624   2              
 625   2         }
 626   1         
 627   1      
 628   1         SetBitMask(ControlReg,0x80);           // stop timer now
 629   1         WriteRawRC(CommandReg,PCD_IDLE); 
 630   1         return status;
 631   1      }
