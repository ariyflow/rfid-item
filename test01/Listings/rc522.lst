 413   1          WriteRawRC(TReloadRegL,30);           
 414   1          WriteRawRC(TReloadRegH,0);
 415   1          WriteRawRC(TModeReg,0x8D);
 416   1          WriteRawRC(TPrescalerReg,0x3E);
 417   1          WriteRawRC(TxAskReg,0x40);
 418   1         
